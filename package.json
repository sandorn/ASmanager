{
    "name": "asmanager",
    "displayName": "ASmanager",
    "description": "%extension.description%",
    "version": "0.0.1",
    "publisher": "Sandhill",
    "license": "SEE LICENSE IN LICENSE",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "ASmanager",
            "properties": {
                "agentSkillsManager.centralRepository": {
                    "type": "string",
                    "default": "~/.agents/skills",
                    "description": "%config.centralRepository.description%"
                },
                "agentSkillsManager.sources": {
                    "type": "array",
                    "default": [
                        "https://github.com/anthropics/skills",
                        "https://github.com/openai/skills",
                        "https://github.com/MoizIbnYousaf/Ai-Agent-Skills",
                        "https://github.com/heilcheng/awesome-agent-skills"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "%config.sources.description%"
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "agentSkillsManager",
                    "title": "%viewsContainer.agentSkillsManager.title%",
                    "icon": "$(tools)"
                }
            ]
        },
        "views": {
            "agentSkillsManager": [
                {
                    "id": "agentSkillsManager.skills",
                    "name": "%view.skills.name%"
                },
                {
                    "id": "agentSkillsManager.agents",
                    "name": "%view.agents.name%"
                },
                {
                    "id": "agentSkillsManager.sources",
                    "name": "%view.sources.name%"
                },
                {
                    "id": "agentSkillsManager.mcp",
                    "name": "%view.mcp.name%"
                }
            ]
        },
        "commands": [
            {
                "command": "agentSkillsManager.initializeRepository",
                "title": "%command.initializeRepository.title%",
                "icon": "$(repo-create)"
            },
            {
                "command": "agentSkillsManager.refresh",
                "title": "%command.refresh.title%",
                "icon": "$(refresh)"
            },
            {
                "command": "agentSkillsManager.openRepository",
                "title": "%command.openRepository.title%",
                "icon": "$(folder-opened)"
            },
            {
                "command": "agentSkillsManager.openManager",
                "title": "%command.openManager.title%",
                "icon": "$(dashboard)"
            },
            {
                "command": "agentSkillsManager.addSource",
                "title": "%command.addSource.title%",
                "icon": "$(add)"
            },
            {
                "command": "agentSkillsManager.updateSources",
                "title": "%command.updateSources.title%",
                "icon": "$(cloud-download)"
            },
            {
                "command": "agentSkillsManager.installSkillFromSource",
                "title": "%command.installSkillFromSource.title%",
                "icon": "$(cloud-download)"
            },
            {
                "command": "agentSkillsManager.detectAgents",
                "title": "%command.detectAgents.title%",
                "icon": "$(search)"
            },
            {
                "command": "agentSkillsManager.diagnoseSkills",
                "title": "%command.diagnoseSkills.title%",
                "icon": "$(pulse)"
            },
            {
                "command": "agentSkillsManager.syncSkill",
                "title": "%command.syncSkill.title%",
                "icon": "$(sync)"
            },
            {
                "command": "agentSkillsManager.syncSkillToAgents",
                "title": "%command.syncSkillToAgents.title%",
                "icon": "$(sync-ignored)"
            },
            {
                "command": "agentSkillsManager.deleteSkill",
                "title": "%command.deleteSkill.title%",
                "icon": "$(trash)"
            },
            {
                "command": "agentSkillsManager.removeSource",
                "title": "%command.removeSource.title%",
                "icon": "$(trash)"
            },
            {
                "command": "agentSkillsManager.showSyncRecords",
                "title": "%command.showSyncRecords.title%",
                "icon": "$(history)"
            },
            {
                "command": "agentSkillsManager.clearSyncRecords",
                "title": "%command.clearSyncRecords.title%",
                "icon": "$(clear-all)"
            },
            {
                "command": "agentSkillsManager.detectMcp",
                "title": "%command.detectMcp.title%",
                "icon": "$(server)"
            },
            {
                "command": "agentSkillsManager.toggleMcpServer",
                "title": "%command.toggleMcpServer.title%",
                "icon": "$(debug-start)"
            },
            {
                "command": "agentSkillsManager.syncMcpServer",
                "title": "%command.syncMcpServer.title%",
                "icon": "$(sync)"
            },
            {
                "command": "agentSkillsManager.backupRepository",
                "title": "%command.backupRepository.title%",
                "icon": "$(export)"
            },
            {
                "command": "agentSkillsManager.restoreRepository",
                "title": "%command.restoreRepository.title%",
                "icon": "$(folder-opened)"
            },
            {
                "command": "agentSkillsManager.renameSkill",
                "title": "%command.renameSkill.title%",
                "icon": "$(edit)"
            },
            {
                "command": "agentSkillsManager.editSkillMarkdown",
                "title": "%command.editSkillMarkdown.title%",
                "icon": "$(edit)"
            },
            {
                "command": "agentSkillsManager.showSourceSkills",
                "title": "%command.showSourceSkills.title%",
                "icon": "$(list-tree)"
            },
            {
                "command": "agentSkillsManager.installAllFromSource",
                "title": "%command.installAllFromSource.title%",
                "icon": "$(cloud-download)"
            },
            {
                "command": "agentSkillsManager.rollbackSync",
                "title": "%command.rollbackSync.title%",
                "icon": "$(debug-reverse-continue)"
            },
            {
                "command": "agentSkillsManager.healthCheckMcp",
                "title": "%command.healthCheckMcp.title%",
                "icon": "$(pulse)"
            },
            {
                "command": "agentSkillsManager.checkSourceUpdates",
                "title": "%command.checkSourceUpdates.title%",
                "icon": "$(sync)"
            },
            {
                "command": "agentSkillsManager.exportConfig",
                "title": "%command.exportConfig.title%",
                "icon": "$(export)"
            },
            {
                "command": "agentSkillsManager.importConfig",
                "title": "%command.importConfig.title%",
                "icon": "$(folder-opened)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "agentSkillsManager.refresh",
                    "when": "view == agentSkillsManager.skills || view == agentSkillsManager.agents || view == agentSkillsManager.sources",
                    "group": "navigation"
                },
                {
                    "command": "agentSkillsManager.openManager",
                    "when": "view == agentSkillsManager.skills || view == agentSkillsManager.agents || view == agentSkillsManager.sources",
                    "group": "navigation"
                },
                {
                    "command": "agentSkillsManager.detectMcp",
                    "when": "view == agentSkillsManager.skills || view == agentSkillsManager.agents || view == agentSkillsManager.sources",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "agentSkillsManager.syncSkill",
                    "when": "view == agentSkillsManager.skills && viewItem == skill",
                    "group": "inline"
                },
                {
                    "command": "agentSkillsManager.deleteSkill",
                    "when": "view == agentSkillsManager.skills && viewItem == skill",
                    "group": "inline@2"
                },
                {
                    "command": "agentSkillsManager.renameSkill",
                    "when": "view == agentSkillsManager.skills && viewItem == skill",
                    "group": "context@1"
                },
                {
                    "command": "agentSkillsManager.editSkillMarkdown",
                    "when": "view == agentSkillsManager.skills && viewItem == skill",
                    "group": "context@2"
                },
                {
                    "command": "agentSkillsManager.installSkillFromSource",
                    "when": "view == agentSkillsManager.sources && viewItem == source",
                    "group": "inline"
                },
                {
                    "command": "agentSkillsManager.removeSource",
                    "when": "view == agentSkillsManager.sources && viewItem == source",
                    "group": "inline@2"
                },
                {
                    "command": "agentSkillsManager.showSourceSkills",
                    "when": "view == agentSkillsManager.sources && viewItem == source",
                    "group": "context@1"
                },
                {
                    "command": "agentSkillsManager.installAllFromSource",
                    "when": "view == agentSkillsManager.sources && viewItem == source",
                    "group": "context@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package --allow-missing-repository"
    },
    "devDependencies": {
        "@types/node": "^22.10.1",
        "@types/vscode": "^1.95.0",
        "@vscode/vsce": "^3.2.1",
        "typescript": "^5.7.2"
    }
}
